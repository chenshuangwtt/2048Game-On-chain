BACKEND_BIND_ADDR=127.0.0.1:18080

# Use the private key that matches the verifier address configured in the contract.
# For local development this can be an Anvil key.
# For Sepolia this must match the deployed verifier address.
VERIFIER_PRIVATE_KEY=0xYOUR_VERIFIER_PRIVATE_KEY

# Persist issued backend seeds so games survive backend restarts.
ISSUED_GAMES_STORE_PATH=./issued-games.json

# Digest/signature domain used by the contract.
SCORE_CONTRACT_ADDRESS=0x5B788710133bA6785C0798561aA8546108006Af7
CHAIN_ID=11155111
